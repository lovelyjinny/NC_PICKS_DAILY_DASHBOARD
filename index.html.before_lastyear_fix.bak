<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>이랜드 NC PICKS</title>
<!-- PWA 설정 -->
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#1C1A17">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="NC PICKS">
<link rel="apple-touch-icon" href="icons/apple-touch-icon.png">
<link rel="apple-touch-icon" sizes="152x152" href="icons/icon-152.png">
<link rel="apple-touch-icon" sizes="144x144" href="icons/icon-144.png">
<link rel="apple-touch-icon" sizes="128x128" href="icons/icon-128.png">
<!-- 스플래시 스크린 색상 (iOS) -->
<meta name="apple-mobile-web-app-status-bar-style" content="black">

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#1C1A17;--bg2:#252220;--bg3:#2E2A26;--bg4:#3A3530;
  --border:#3E3830;--border2:#4E4640;
  --text:#F0EDE8;--text2:#B8B0A5;--text3:#7A7268;
  --teal:#4ECDC4;--teal-bg:rgba(78,205,196,0.12);
  --pink:#FF6B9D;--pink-bg:rgba(255,107,157,0.12);
  --yellow:#FFD166;--yellow-bg:rgba(255,209,102,0.12);
  --purple:#B48FE0;--purple-bg:rgba(180,143,224,0.12);
  --green:#6BCB77;--green-bg:rgba(107,203,119,0.12);
  --red:#FF6B6B;--red-bg:rgba(255,107,107,0.12);
  --nav-h:56px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow-x:hidden}
body{font-family:"Noto Sans KR",sans-serif;background:var(--bg);color:var(--text);font-size:13px}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* ══ 데스크탑: 사이드바 레이아웃 ══ */
@media(min-width:768px){
  .sidebar{position:fixed;top:0;left:0;width:200px;height:100vh;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:100}
  .main{margin-left:200px}
  .bottom-nav{display:none!important}
  .topbar{padding:11px 24px}
  .fbar{padding:9px 24px}
  .body{padding:18px 24px}
  .krow{grid-template-columns:repeat(4,1fr)}
  .krow5{grid-template-columns:repeat(5,1fr)}
  .sum-row{grid-template-columns:repeat(4,1fr)}
  .g2{grid-template-columns:3fr 2fr}
  .g2e{grid-template-columns:1fr 1fr}
  .g3{grid-template-columns:1fr 1fr 1fr}
  .g4{grid-template-columns:repeat(4,1fr)}
  .type-grid{grid-template-columns:repeat(4,1fr)}
  .dp{width:660px}
}

/* ══ 모바일 레이아웃 ══ */
@media(max-width:767px){
  .sidebar{display:none!important}
  .main{margin-left:0;padding-bottom:calc(var(--nav-h) + env(safe-area-inset-bottom))}
  .topbar{padding:10px 16px}
  .fbar{padding:8px 16px;flex-wrap:wrap;gap:8px}
  .fbar .fright{width:100%;justify-content:flex-end}
  .body{padding:12px 14px}
  .krow,.krow5{grid-template-columns:repeat(2,1fr)}
  .sum-row{grid-template-columns:repeat(2,1fr)}
  .g2,.g2e,.g3,.g4{grid-template-columns:1fr}
  .type-grid{grid-template-columns:repeat(2,1fr)}
  .dp{width:100%;border-left:none;border-top:1px solid var(--border2)}
  .overlay{align-items:flex-end}
  @keyframes slideIn{from{transform:translateY(100%)}to{transform:translateY(0)}}
  .page-title{font-size:15px}
  .kpi-v{font-size:20px}
  .sum-num{font-size:26px}
  .tc-amt{font-size:18px}
  .card{padding:12px}
  .tbl{font-size:11px}
  .tbl th,.tbl td{padding:6px 6px}
}

/* ══ 공통 ══ */
.logo-wrap{padding:22px 18px 16px;border-bottom:1px solid var(--border)}
.logo-e{font-size:22px;font-weight:900;color:var(--text);letter-spacing:-1px}
.logo-nc{font-size:10px;color:var(--teal);letter-spacing:2px;font-weight:600}
.logo-sub{font-size:9px;color:var(--text3);letter-spacing:1.5px;margin-top:1px;text-transform:uppercase}
.nav{flex:1;padding:12px 8px;overflow-y:auto}
.nav-group{font-size:9px;color:var(--text3);letter-spacing:2px;padding:10px 10px 4px;text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:7px;cursor:pointer;color:var(--text3);font-size:12px;margin-bottom:2px;transition:all .15s;position:relative}
.nav-item:hover{background:rgba(255,255,255,0.04);color:var(--text2)}
.nav-item.on{background:var(--teal-bg);color:var(--teal)}
.nav-item.on::before{content:"";position:absolute;left:0;top:25%;height:50%;width:2px;background:var(--teal);border-radius:2px}
.nav-icon{font-size:13px;flex-shrink:0}
.sidebar-foot{padding:12px 18px;border-top:1px solid var(--border)}
.live-dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--green);margin-right:5px;box-shadow:0 0 5px var(--green)}
.live-txt{font-size:10px;color:var(--text3)}
.date-txt{font-size:10px;color:var(--text3);font-family:"DM Mono",monospace;margin-top:3px}

/* ── 탑바 ── */
.topbar{background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.page-title{font-size:18px;font-weight:700;color:var(--text)}
.topbar-r{display:flex;align-items:center;gap:6px}
.chip{font-size:10px;padding:3px 8px;border-radius:20px;border:1px solid var(--border2);color:var(--text2);font-family:"DM Mono",monospace}
.chip.live{border-color:var(--green);color:var(--green);background:var(--green-bg)}
.chip.warn{border-color:var(--red);color:var(--red);background:var(--red-bg)}
.chip.date{border-color:var(--teal);color:var(--teal);background:var(--teal-bg)}

/* ── 필터 바 ── */
.fbar{background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.fl{font-size:10px;color:var(--text3);flex-shrink:0}
.type-filter{display:flex;gap:4px;flex-wrap:wrap}
.tf-btn{font-size:10px;padding:4px 10px;border-radius:20px;border:1px solid var(--border2);color:var(--text3);background:transparent;cursor:pointer;font-family:inherit;transition:all .15s;white-space:nowrap}
.tf-btn:hover{color:var(--text2);background:var(--bg3)}
.tf-btn.on{background:var(--teal-bg);border-color:var(--teal);color:var(--teal);font-weight:600}
.fright{display:flex;align-items:center;gap:6px;margin-left:auto}
.prog-label{font-size:10px;color:var(--text3);white-space:nowrap}
.prog-bg{width:60px;height:3px;background:var(--bg4);border-radius:2px;overflow:hidden}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--teal),var(--purple));border-radius:2px}
.prog-num{font-size:11px;font-weight:700;color:var(--teal);font-family:"DM Mono",monospace}

/* ── 본문 ── */
.body{min-height:calc(100vh - 120px)}
.page{display:none}.page.on{display:block}
.gap{margin-bottom:10px}

/* ── KPI ── */
.krow{display:grid;gap:8px;margin-bottom:12px}
.krow5{display:grid;gap:8px;margin-bottom:12px}
.kpi{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:12px 14px;position:relative;overflow:hidden;transition:all .15s}
.kpi:hover{border-color:var(--border2)}
.kpi-l{font-size:9px;color:var(--text3);letter-spacing:.5px;text-transform:uppercase;margin-bottom:6px;font-weight:500}
.kpi-v{font-family:"DM Mono",monospace;line-height:1;font-weight:700}
.kpi-d{font-size:10px;margin-top:4px;color:var(--text3)}
.kpi-acc{position:absolute;right:10px;top:10px;font-size:16px;opacity:.5}

/* ── 카드 ── */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:10px}
.card-t{font-size:10px;color:var(--text3);letter-spacing:1px;text-transform:uppercase;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center;font-weight:600}
.g2,.g2e,.g3,.g4{display:grid;gap:10px;margin-bottom:10px}
.sum-row{display:grid;gap:8px;margin-bottom:12px}
.sum-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:14px;position:relative;overflow:hidden}
.sum-card::before{content:"";position:absolute;top:0;left:0;right:0;height:2px}
.sc1::before{background:linear-gradient(90deg,var(--teal),#2aa8a0)}
.sc2::before{background:linear-gradient(90deg,var(--purple),#8048c0)}
.sc3::before{background:linear-gradient(90deg,var(--yellow),#e5b030)}
.sc4::before{background:linear-gradient(90deg,var(--pink),#e0457a)}
.sum-dot{width:6px;height:6px;border-radius:50%;margin-bottom:6px}
.sum-label{font-size:10px;color:var(--text2);margin-bottom:5px;font-weight:500}
.sum-num{font-family:"DM Mono",monospace;font-weight:700;line-height:1}
.sum-sub{font-size:10px;color:var(--text3);margin-top:4px}

/* ── 바 ── */
.br{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.bn{width:72px;font-size:11px;color:var(--text2);flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.bg2b{flex:1;background:rgba(255,255,255,0.04);border-radius:2px;height:5px;overflow:hidden}
.bf{height:100%;border-radius:2px}
.bv{width:46px;font-size:11px;text-align:right;font-family:"DM Mono",monospace;color:var(--text2)}

/* ── 테이블 ── */
.tbl{width:100%;border-collapse:collapse}
.tbl th{color:var(--text3);font-weight:500;font-size:9px;letter-spacing:1px;text-transform:uppercase;padding:5px 6px;border-bottom:1px solid var(--border);text-align:left}
.tbl td{padding:7px 6px;border-bottom:1px solid var(--border);color:var(--text2)}
.tbl td:first-child{color:var(--text)}
.tbl tr:last-child td{border-bottom:none}
.tbl tr:hover td{background:rgba(255,255,255,0.02);cursor:pointer}
.tbl-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch}

/* ── 필 ── */
.pill{display:inline-block;font-size:9px;padding:2px 6px;border-radius:20px;font-family:"DM Mono",monospace}
.pg{background:var(--green-bg);color:var(--green);border:1px solid rgba(107,203,119,.2)}
.pr{background:var(--red-bg);color:var(--red);border:1px solid rgba(255,107,107,.2)}
.pa{background:var(--yellow-bg);color:var(--yellow);border:1px solid rgba(255,209,102,.2)}

/* ── 유형 카드 ── */
.type-grid{display:grid;gap:8px;margin-bottom:12px}
.tc{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:12px 14px;transition:all .15s}
.tc:hover{border-color:var(--border2)}
.tc-bar{height:2px;width:24px;border-radius:1px;margin-bottom:8px}
.tc-name{font-size:9px;color:var(--text3);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:4px}
.tc-amt{font-family:"DM Mono",monospace;font-weight:700;margin-bottom:3px}
.tc-sub{font-size:9px;color:var(--text3);font-family:"DM Mono",monospace}

/* ── 범례 ── */
.leg{display:flex;gap:8px;font-size:9px;color:var(--text3);flex-wrap:wrap}
.leg span{display:flex;align-items:center;gap:3px}
.dot{width:6px;height:6px;border-radius:50%;display:inline-block;flex-shrink:0}
.warn-box{background:var(--red-bg);border:1px solid rgba(255,107,107,.2);border-radius:8px;padding:10px 12px;font-size:10px;color:var(--red);margin-top:8px;font-family:"DM Mono",monospace}

/* ══ 하단 네비 (모바일 전용) ══ */
.bottom-nav{
  position:fixed;bottom:0;left:0;right:0;
  background:var(--bg2);
  border-top:1px solid var(--border);
  display:flex;
  padding-bottom:env(safe-area-inset-bottom);
  z-index:100;
}
.bn-item{
  flex:1;display:flex;flex-direction:column;align-items:center;
  justify-content:center;padding:8px 4px;cursor:pointer;
  color:var(--text3);transition:all .15s;border:none;background:none;
  font-family:inherit;
}
.bn-item.on{color:var(--teal)}
.bn-icon{font-size:18px;margin-bottom:2px}
.bn-label{font-size:9px;letter-spacing:.3px;font-weight:500}
.bn-item.on .bn-label{color:var(--teal)}

/* ══ 상세 패널 ══ */
.overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.75);z-index:200;display:none;justify-content:flex-end}
.overlay.open{display:flex}
.dp{height:100vh;background:var(--bg2);border-left:1px solid var(--border2);overflow-y:auto;animation:slideIn .2s ease}
@keyframes slideIn{from{transform:translateX(100%)}to{transform:translateX(0)}}
@media(max-width:767px){
  .overlay{align-items:flex-end}
  .dp{width:100%!important;height:90vh;border-left:none;border-top:1px solid var(--border2);border-radius:16px 16px 0 0}
  @keyframes slideIn{from{transform:translateY(100%)}to{transform:translateY(0)}}
  .dp-hdr::before{content:"";display:block;width:36px;height:3px;background:var(--border2);border-radius:2px;margin:0 auto 14px}
}
.dp-hdr{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;justify-content:space-between;position:sticky;top:0;background:var(--bg2);z-index:10}
.dp-name{font-size:18px;font-weight:700;color:var(--text)}
.dp-meta{font-size:10px;color:var(--text3);margin-top:2px}
.dp-close{width:26px;height:26px;border-radius:6px;border:1px solid var(--border2);background:var(--bg3);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--text3);flex-shrink:0}
.dp-body{padding:16px 20px}
.dp-krow{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:14px}
@media(min-width:500px){.dp-krow{grid-template-columns:repeat(4,1fr)}}
.dp-kpi{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 12px}
.dp-kpi-l{font-size:8px;color:var(--text3);letter-spacing:.5px;text-transform:uppercase;margin-bottom:4px}
.dp-kpi-v{font-size:16px;font-weight:700;font-family:"DM Mono",monospace;line-height:1}
.dp-kpi-s{font-size:9px;color:var(--text3);margin-top:3px}
.dp-sec{margin-bottom:14px}
.dp-sec-title{font-size:10px;color:var(--text3);letter-spacing:.5px;font-weight:600;margin-bottom:7px;padding-bottom:5px;border-bottom:1px solid var(--border)}
.dp-tbl{width:100%;border-collapse:collapse;font-size:11px}
.dp-tbl th{color:var(--text3);font-weight:400;font-size:9px;letter-spacing:1px;text-transform:uppercase;padding:5px 6px;border-bottom:1px solid var(--border);text-align:left}
.dp-tbl td{padding:6px 6px;border-bottom:1px solid var(--border);color:var(--text2);font-family:"DM Mono",monospace}
.dp-tbl td:first-child{font-family:"Noto Sans KR",sans-serif;color:var(--text)}
.dp-tbl tr:last-child td{border-bottom:none}
.dp-ind{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:7px;margin-bottom:7px}
.dp-ind-l{display:flex;align-items:center;gap:8px}
.ind-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.ind-label{font-size:11px;color:var(--text);font-weight:500}
.ind-desc{font-size:9px;color:var(--text3);margin-top:1px}
.ind-badge{font-size:9px;padding:2px 8px;border-radius:10px;font-weight:600;flex-shrink:0}
.b-ok{background:var(--green-bg);color:var(--green)}
.b-warn{background:var(--yellow-bg);color:var(--yellow)}
.b-alert{background:var(--red-bg);color:var(--red)}
</style>
</head>
<body>

<!-- 데스크탑 사이드바 -->
<nav class="sidebar">
  <div class="logo-wrap">
    <div class="logo-e">ELAND</div>
    <div class="logo-nc">NC PICKS</div>
    <div class="logo-sub">상품기획 모니터링</div>
  </div>
  <div class="nav">
    <div class="nav-group">실적</div>
    <div class="nav-item on" onclick="GO('p0',this)"><span class="nav-icon">📊</span>일매출 현황</div>
    <div class="nav-item" onclick="GO('p1',this)"><span class="nav-icon">🏪</span>지점별 실적</div>
    <div class="nav-item" onclick="GO('p2',this)"><span class="nav-icon">🗂</span>지점 유형별</div>
    <div class="nav-item" onclick="GO('p3',this)"><span class="nav-icon">📈</span>월별 트렌드</div>
    <div class="nav-group">재고·물류</div>
    <div class="nav-item" onclick="GO('p4',this)"><span class="nav-icon">📦</span>입고·판매</div>
    <div class="nav-item" onclick="GO('p5',this)"><span class="nav-icon">🗃</span>재고 현황</div>
    <div class="nav-group">픽스 전용</div>
    <div class="nav-item" onclick="GO('p6',this)"><span class="nav-icon">⭐</span>픽스 평매출</div>
  </div>
  <div class="sidebar-foot">
    <div><span class="live-dot"></span><span class="live-txt">LIVE DATA</span></div>
    <div class="date-txt">2026-04-08 기준</div>
  </div>
</nav>

<!-- 메인 -->
<div class="main">
  <!-- 탑바 -->
  <div class="topbar">
    <div class="page-title" id="page-title">일매출 현황</div>
    <div class="topbar-r">
      <span class="chip live">● LIVE</span>
      <span class="chip date" id="date-chip">04-08</span>
      <span class="chip warn" id="neg-chip" style="display:none"></span>
    </div>
  </div>

  <!-- 필터 바 -->
  <div class="fbar">
    <span class="fl">유형</span>
    <div class="type-filter">
      <button class="tf-btn on" onclick="filterType('전체',this)">전체</button>
      <button class="tf-btn" onclick="filterType('픽스',this)">픽스</button>
      <button class="tf-btn" onclick="filterType('픽스 키즈',this)">키즈</button>
      <button class="tf-btn" onclick="filterType('중간관리',this)">중간</button>
      <button class="tf-btn" onclick="filterType('기타',this)">기타</button>
    </div>
    <div class="fright">
      <div class="prog-bg"><div class="prog-fill" style="width:27%"></div></div>
      <span class="prog-num">27%</span>
    </div>
  </div>

  <div class="body">

  <!-- P0 일매출 현황 -->
  <div class="page on" id="p0">
    <div class="krow">
      <div class="kpi"><div class="kpi-acc">📈</div><div class="kpi-l">당월 누계</div><div class="kpi-v" id="k-tot" style="color:var(--teal);font-size:22px">—</div><div class="kpi-d" id="k-tot-d">—</div></div>
      <div class="kpi"><div class="kpi-acc">🎯</div><div class="kpi-l">달성률</div><div class="kpi-v" id="k-rate" style="font-size:22px">—</div><div class="kpi-d" id="k-rate-d">—</div></div>
      <div class="kpi"><div class="kpi-acc">📅</div><div class="kpi-l">전년 성장</div><div class="kpi-v" id="k-growth" style="font-size:22px">—</div><div class="kpi-d">YoY</div></div>
      <div class="kpi"><div class="kpi-acc">🏆</div><div class="kpi-l">일 최고</div><div class="kpi-v" id="k-best" style="color:var(--purple);font-size:22px">—</div><div class="kpi-d" id="k-best-d">—</div></div>
    </div>
    <div class="sum-row">
      <div class="sum-card sc1"><div class="sum-dot" style="background:var(--teal)"></div><div class="sum-label">남성</div><div class="sum-num" style="color:var(--teal);font-size:24px" id="s-m">—</div><div class="sum-sub" id="s-ms">—</div></div>
      <div class="sum-card sc2"><div class="sum-dot" style="background:var(--purple)"></div><div class="sum-label">여성</div><div class="sum-num" style="color:var(--purple);font-size:24px" id="s-w">—</div><div class="sum-sub" id="s-ws">—</div></div>
      <div class="sum-card sc3"><div class="sum-dot" style="background:var(--yellow)"></div><div class="sum-label">아동</div><div class="sum-num" style="color:var(--yellow);font-size:24px" id="s-k">—</div><div class="sum-sub" id="s-ks">—</div></div>
      <div class="sum-card sc4"><div class="sum-dot" style="background:var(--pink)"></div><div class="sum-label">집계 지점</div><div class="sum-num" style="color:var(--pink);font-size:24px" id="s-br">—</div><div class="sum-sub">개 지점</div></div>
    </div>
    <div class="card">
      <div class="card-t">일별 매출 추이<div class="leg"><span><span class="dot" style="background:var(--teal)"></span>실적</span><span><span style="width:12px;height:1.5px;background:var(--yellow);display:inline-block"></span>목표</span><span><span style="width:12px;height:1.5px;background:#555;display:inline-block"></span>전년</span></div></div>
      <div style="position:relative;height:180px"><canvas id="c-daily"></canvas></div>
    </div>
    <div class="g2e">
