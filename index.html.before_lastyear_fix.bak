      <div class="card"><div class="card-t">셀별 구성<div id="cell-leg" style="display:flex;gap:6px;font-size:9px;color:var(--text3)"></div></div><div style="position:relative;height:120px"><canvas id="c-pie"></canvas></div></div>
    </div>
    <div class="g2e">
      <div class="card"><div class="card-t">달성율 추이</div><div style="position:relative;height:120px"><canvas id="c-rate"></canvas></div></div>
      <div class="card"><div class="card-t">YoY 성장율</div><div style="position:relative;height:120px"><canvas id="c-growth"></canvas></div></div>
    </div>
    <div class="card">
      <div class="card-t">셀별 핵심 지표</div>
