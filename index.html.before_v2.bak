      <div class="kpi"><div class="kpi-l">최고 매출</div><div class="kpi-v" id="tr-best" style="color:var(--yellow);font-size:18px">—</div><div class="kpi-d" id="tr-best-d">—</div></div>
      <div class="kpi"><div class="kpi-l">최근 매총율</div><div class="kpi-v" id="tr-mg" style="color:var(--pink);font-size:22px">—</div><div class="kpi-d">최근월</div></div>
