0.0},{"d":"05-12","t":3870580.0},{"d":"05-13","t":6061480.0}]}};
const f8=v=>{if(!v&&v!==0)return"—";const a=Math.abs(v);if(a>=1e8)return(v/1e8).toFixed(1)+"억";if(a>=1e6)return(v/1e6).toFixed(0)+"백만";return v;};
const fn=v=>Math.round(v||0).toLocaleString();
const fp=v=>v!=null?v.toFixed(1)+"%":"—";
const gc="rgba(255,255,255,0.05)",lc="rgba(200,190,175,0.5)";
const CC={남성:"#4ECDC4",여성:"#FF6B9D",아동:"#FFD166"};
const TC={픽스:"#4ECDC4","픽스 키즈":"#B48FE0",중간관리:"#FFD166",기타:"#7A7268"};
const ptitles={p0:"일매출 현황",p1:"지점별 실적",p2:"지점 유형별",p3:"월별 트렌드",p4:"입고·판매",p5:"재고 현황",p6:"픽스 평매출"};
Chart.defaults.color=lc;Chart.defaults.borderColor=gc;
let dpChart=null,currentType="전체";

// ── 네비 ────────────────────────────────────────────
function GO(id,el){
  document.querySelectorAll(".page").forEach(p=>p.className="page");
  document.querySelectorAll(".nav-item").forEach(n=>n.className="nav-item");
  document.querySelectorAll(".bn-item").forEach(b=>b.classList.remove("on"));
  document.getElementById(id).className="page on";
  if(el){
    // 사이드바 아이템
    if(el.classList.contains("nav-item")) el.className="nav-item on";
    // 하단 네비 아이템
    if(el.classList.contains("bn-item")) el.classList.add("on");
  }
  document.getElementById("page-title").textContent=ptitles[id]||"—";
  window.scrollTo(0,0);
}
function showMoreMenu(){
  const m=document.getElementById("more-menu");
  m.style.display=m.style.display==="none"?"block":"none";
}
function hideMoreMenu(){document.getElementById("more-menu").style.display="none";}
document.addEventListener("click",e=>{
  const mm=document.getElementById("more-menu");
  if(!mm.contains(e.target)&&!e.target.closest("[onclick='showMoreMenu()']"))
    mm.style.display="none";
});

function pil(v,g,a){return"<span class=\"pill "+(v>=g?"pg":v>=a?"pa":"pr")+"\">"+(v!=null?v.toFixed(1)+"%":"—")+"</span>";}

const d=DATA,daily=d.daily||[],branches=d.branches||[];
const cellData=d.cell||{},typeData=d.type||{},trend=d.trend||[];
const sm=d.sm||[],inv=d.inv||[],fix=d.fix||[];
const cellByBranch=d.cell_by_branch||{},dailyByBranch=d.daily_by_branch||{};
const tot=daily.reduce((s,r)=>s+(r.t||0),0);
const tot_ly=daily.reduce((s,r)=>s+(r.ly||0),0);
const tot_tgt=daily.reduce((s,r)=>s+(r.target||0),0);
const best=daily.length?daily.reduce((a,b)=>a.t>b.t?a:b):{t:0,d:"—"};
const growth=tot_ly>0?((tot/tot_ly-1)*100).toFixed(1):null;
const rate=tot_tgt>0?(tot/tot_tgt*100).toFixed(1):null;
const cellTot={남성:daily.reduce((s,r)=>s+(r.m||0),0),여성:daily.reduce((s,r)=>s+(r.w||0),0),아동:daily.reduce((s,r)=>s+(r.k||0),0)};

// P0
document.getElementById("k-tot").textContent=f8(tot);
document.getElementById("k-tot-d").textContent="04-08 누계";
document.getElementById("k-rate").textContent=rate?rate+"%":"—";
document.getElementById("k-rate").style.color=rate&&+rate>=100?"var(--green)":"var(--red)";
document.getElementById("k-rate-d").textContent=rate?(+rate>=100?"▲달성":"▼미달"):"—";
document.getElementById("k-growth").textContent=growth?(+growth>=0?"+":"")+growth+"%":"—";
document.getElementById("k-growth").style.color=growth&&+growth>=0?"var(--green)":"var(--red)";
document.getElementById("k-best").textContent=f8(best.t);
document.getElementById("k-best-d").textContent=best.d+" 최고";
document.getElementById("s-m").textContent=f8(cellTot["남성"]);
document.getElementById("s-w").textContent=f8(cellTot["여성"]);
document.getElementById("s-k").textContent=f8(cellTot["아동"]);
document.getElementById("s-br").textContent=branches.length;
["ms","ws","ks"].forEach((id,i)=>{const cn=["남성","여성","아동"][i];document.getElementById("s-"+id).textContent=f8(cellTot[cn]/8)+" 일평균";});

new Chart(document.getElementById("c-daily"),{type:"bar",data:{labels:daily.map(r=>r.d),datasets:[
  {label:"실적",data:daily.map(r=>r.t),backgroundColor:"rgba(78,205,196,.7)",borderRadius:4,order:2},
  {label:"목표",data:daily.map(r=>r.target),type:"line",borderColor:"rgba(255,209,102,.6)",borderWidth:1.5,borderDash:[5,4],pointRadius:0,fill:false,order:1},
  {label:"전년",data:daily.map(r=>r.ly),type:"line",borderColor:"rgba(100,95,90,.5)",borderWidth:1,borderDash:[3,3],pointRadius:0,fill:false,order:1},
]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:"rgba(25,22,18,.95)",borderColor:"rgba(255,255,255,.1)",borderWidth:1,padding:8,callbacks:{label:c=>c.dataset.label+": "+f8(c.raw)}}},scales:{x:{grid:{color:gc},ticks:{color:lc,font:{size:9}}},y:{grid:{color:gc},ticks:{color:lc,font:{size:9},callback:v=>f8(v)}}}}});

new Chart(document.getElementById("c-cell-bar"),{type:"bar",data:{labels:["남성","여성","아동"],datasets:[{data:[cellTot["남성"],cellTot["여성"],cellTot["아동"]],backgroundColor:["rgba(78,205,196,.7)","rgba(255,107,157,.7)","rgba(255,209,102,.7)"],borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:gc},ticks:{color:lc,font:{size:10}}},y:{grid:{color:gc},ticks:{color:lc,font:{size:10},callback:v=>f8(v)}}}}});

const cTotArr=[cellTot["남성"],cellTot["여성"],cellTot["아동"]];
const totAll2=cTotArr.reduce((a,b)=>a+b,0);
const cPie=new Chart(document.getElementById("c-pie"),{type:"doughnut",data:{labels:["남성","여성","아동"],datasets:[{data:cTotArr,backgroundColor:["rgba(78,205,196,.8)","rgba(255,107,157,.8)","rgba(255,209,102,.8)"],borderWidth:0}]},options:{responsive:true,maintainAspectRatio:false,cutout:"62%",plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>c.label+": "+f8(c.raw)}}}}});
const lg=document.getElementById("cell-leg");
["남성","여성","아동"].forEach((cn,i)=>{lg.innerHTML+=`<span style="display:flex;align-items:center;gap:3px"><span style="width:6px;height:6px;border-radius:50%;background:${CC[cn]};display:inline-block"></span>${cn} ${Math.round(cTotArr[i]/totAll2*100)}%</span>`;});

new Chart(document.getElementById("c-rate"),{type:"line",data:{labels:daily.map(r=>r.d),datasets:[{label:"달성율%",data:daily.map(r=>r.rate),borderColor:"#4D9FFF",backgroundColor:"rgba(77,159,255,.1)",borderWidth:2,pointRadius:2,fill:true,tension:0.3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:gc},ticks:{color:lc,font:{size:9}}},y:{grid:{color:gc},ticks:{color:lc,font:{size:9},callback:v=>v+"%"}}}}});
new Chart(document.getElementById("c-growth"),{type:"bar",data:{labels:daily.map(r=>r.d),datasets:[{label:"YoY%",data:daily.map(r=>r.growth),backgroundColor:daily.map(r=>(r.growth||0)>=0?"rgba(107,203,119,.65)":"rgba(255,107,107,.65)"),borderRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:gc},ticks:{color:lc,font:{size:9}}},y:{grid:{color:gc},ticks:{color:lc,font:{size:9},callback:v=>v+"%"}}}}});

const ctbl=document.getElementById("cell-tbl");
["남성","여성","아동"].forEach(cn=>{const c=cellData[cn];if(!c)return;ctbl.innerHTML+=`<tr><td style="color:${CC[cn]};font-weight:600">${cn}</td><td style="text-align:right">${f8(c.total)}</td><td style="text-align:right">${pil(c.sell_rate||0,30,15)}</td><td style="text-align:right;color:var(--text3)">${fp(c.tcr)}</td><td style="text-align:right">${pil(c.margin||0,20,0)}</td></tr>`;});

// P1
function initP1(filtered){
  filtered=filtered||branches;
  document.getElementById("b-cnt").textContent=filtered.length+"개";
  document.getElementById("b-top").textContent=filtered[0]?.name||"—";
  document.getElementById("b-top-a").textContent=f8(filtered[0]?.total||0);
  const sr=filtered.filter(b=>b.sell_rate),mg=filtered.filter(b=>b.margin);
  document.getElementById("b-sell").textContent=sr.length?(sr.reduce((s,b)=>s+(b.sell_rate||0),0)/sr.length).toFixed(1)+"%":"—";
  document.getElementById("b-mg").textContent=mg.length?(mg.reduce((s,b)=>s+(b.margin||0),0)/mg.length).toFixed(1)+"%":"—";
  const bMax=filtered[0]?.total||1,bb=document.getElementById("branch-bars");bb.innerHTML="";
  filtered.slice(0,15).forEach((b,i)=>{const op=Math.max(1-i*0.04,.35);bb.innerHTML+=`<div class="br"><div class="bn">${b.name}</div><div class="bg2b"><div class="bf" style="width:${Math.round(b.total/bMax*100)}%;background:rgba(78,205,196,${op})"></div></div><div class="bv">${f8(b.total)}</div></div>`;});
  const btbl=document.getElementById("branch-tbl");btbl.innerHTML="";
  filtered.forEach((b,i)=>{const tc=TC[b.type]||"#7A7268";btbl.innerHTML+=`<tr onclick="openDetail('${b.name}')"><td style="color:var(--text3)">${i+1}</td><td style="color:var(--teal);cursor:pointer">${b.name}</td><td><span style="color:${tc};font-size:9px">${b.type}</span></td><td style="text-align:right">${f8(b.total)}</td><td style="text-align:right">${pil(b.sell_rate||0,30,15)}</td><td style="text-align:right">${pil(b.margin||0,20,0)}</td></tr>`;});
}

// P2
const tpOrder=[["픽스","#4ECDC4"],["픽스 키즈","#B48FE0"],["중간관리","#FFD166"],["기타","#7A7268"]];
const tc2=document.getElementById("type-cards");
tpOrder.forEach(([tp,color])=>{const td=typeData[tp];if(!td)return;const ts=Object.values(td).reduce((s,c)=>s+(c.total||0),0);const am=(Object.values(td).reduce((s,c)=>s+(c.margin||0),0)/Object.values(td).length).toFixed(1);tc2.innerHTML+=`<div class="tc"><div class="tc-bar" style="background:${color}"></div><div class="tc-name">${tp}</div><div class="tc-amt" style="color:${color};font-size:20px">${f8(ts)}</div><div class="tc-sub">매총율 ${am}%</div></div>`;});
new Chart(document.getElementById("c-type"),{type:"bar",data:{labels:daily.map(r=>r.d),datasets:tpOrder.map(([tp,color])=>{const td=typeData[tp];const ratio=td?Object.values(td).reduce((s,c)=>s+(c.total||0),0)/tot:0;const bg=color==="#7A7268"?"rgba(100,95,90,.55)":color+"b3";return{label:tp,data:daily.map(r=>r.t*ratio),backgroundColor:bg,borderRadius:3,stack:"s"};})},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>c.dataset.label+": "+f8(c.raw)}}},scales:{x:{stacked:true,grid:{color:gc},ticks:{color:lc,font:{size:9}}},y:{stacked:true,grid:{color:gc},ticks:{color:lc,font:{size:9},callback:v=>f8(v)}}}}});
const ttbl=document.getElementById("type-tbl");
tpOrder.forEach(([tp,color])=>{const td=typeData[tp];if(!td)return;Object.entries(td).forEach(([cn,cv],j)=>{ttbl.innerHTML+=`<tr>${j===0?`<td rowspan="${Object.keys(td).length}" style="color:${color};font-weight:600">${tp}</td>`:""}<td style="color:${CC[cn]||"var(--text2)"}">${cn}</td><td style="text-align:right">${f8(cv.total)}</td><td style="text-align:right">${pil(cv.sell_rate||0,30,15)}</td><td style="text-align:right">${pil(cv.margin||0,20,0)}</td></tr>`;});});

// P3
const bestT=trend.reduce((a,b)=>a.sales>b.sales?a:b,{sales:0,ym:"—"}),latT=trend[trend.length-1]||{};
document.getElementById("tr-best").textContent=f8(bestT.sales);document.getElementById("tr-best-d").textContent=bestT.ym;
document.getElementById("tr-mg").textContent=fp(latT.margin);document.getElementById("tr-sr").textContent=fp(latT.sell_rate);
const lbl=trend.map(r=>r.ym.slice(2));
new Chart(document.getElementById("c-trend"),{type:"bar",data:{labels:lbl,datasets:[{label:"매출",data:trend.map(r=>r.sales),backgroundColor:trend.map(r=>r.ym.startsWith("2026")?"rgba(78,205,196,.75)":"rgba(78,205,196,.28)"),borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>f8(c.raw)}}},scales:{x:{grid:{color:gc},ticks:{color:lc,font:{size:9}}},y:{grid:{color:gc},ticks:{color:lc,font:{size:9},callback:v=>f8(v)}}}}});
new Chart(document.getElementById("c-tr-mg"),{type:"line",data:{labels:lbl,datasets:[{label:"매총율%",data:trend.map(r=>r.margin),borderColor:"#FF6B9D",backgroundColor:"rgba(255,107,157,.1)",borderWidth:2,pointRadius:2,fill:true,tension:0.4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:gc},ticks:{color:lc,font:{size:9}}},y:{grid:{color:gc},ticks:{color:lc,font:{size:9},callback:v=>v+"%"}}}}});
new Chart(document.getElementById("c-tr-st"),{type:"line",data:{labels:lbl,datasets:[{label:"재고",data:trend.map(r=>(r.stock||0)/1e9),borderColor:"#B48FE0",backgroundColor:"rgba(180,143,224,.1)",borderWidth:2,pointRadius:2,fill:true,tension:0.4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:gc},ticks:{color:lc,font:{size:9}}},y:{grid:{color:gc},ticks:{color:lc,font:{size:9},callback:v=>v+"B"}}}}});

// P4
const ti=sm.reduce((s,r)=>s+r.iq,0),ts=sm.reduce((s,r)=>s+r.sq,0),bs=sm.reduce((a,b)=>a.sq>b.sq?a:b,{sq:0,d:"—"});
document.getElementById("s-in").textContent=fn(ti);document.getElementById("s-sl").textContent=fn(ts);
document.getElementById("s-rt").textContent=ti>0?Math.round(ts/ti*100)+"%":"—";
document.getElementById("s-best").textContent=bs.d;document.getElementById("s-best-d").textContent=fn(bs.sq)+"개";
new Chart(document.getElementById("c-sm"),{type:"bar",data:{labels:sm.map(r=>r.d),datasets:[{label:"입고량",data:sm.map(r=>r.iq),backgroundColor:"rgba(77,159,255,.65)",borderRadius:4},{label:"판매량",data:sm.map(r=>r.sq),backgroundColor:"rgba(78,205,196,.65)",borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>c.dataset.label+": "+fn(c.raw)}}},scales:{x:{grid:{color:gc},ticks:{color:lc,font:{size:9}}},y:{grid:{color:gc},ticks:{color:lc,font:{size:9},callback:v=>fn(v)}}}}});

// P5
const noWh=inv.filter(r=>r.name!=="물류 센타"),negItems=inv.filter(r=>r.neg_q<0);
document.getElementById("i-qty").textContent=fn(noWh.reduce((s,r)=>s+r.qty,0));
document.getElementById("i-amt").textContent=f8(noWh.reduce((s,r)=>s+r.amt,0));
document.getElementById("i-neg").textContent=negItems.length+"건";
if(negItems.length>0){const nc=document.getElementById("neg-chip");nc.style.display="";nc.textContent="⚠ "+negItems.length+"건";}
const topI=noWh.reduce((a,b)=>a.amt>b.amt?a:b,{name:"—",amt:0});
document.getElementById("i-top").textContent=topI.name;document.getElementById("i-top-a").textContent=f8(topI.amt);
const iTop=noWh.slice().sort((a,b)=>b.amt-a.amt).slice(0,12),iMax=iTop[0]?.amt||1,ib=document.getElementById("inv-bars");
iTop.forEach((r,i)=>{const op=Math.max(1-i*0.05,.3);ib.innerHTML+=`<div class="br"><div class="bn">${r.name} ${r.cell}</div><div class="bg2b"><div class="bf" style="width:${Math.round(r.amt/iMax*100)}%;background:rgba(180,143,224,${op})"></div></div><div class="bv" style="color:#B48FE0">${f8(r.amt)}</div></div>`;});
const nt=document.getElementById("neg-tbl");
negItems.forEach(r=>{nt.innerHTML+=`<tr><td>${r.name}</td><td style="color:${CC[r.cell]||"var(--text2)"}">${r.cell}</td><td style="text-align:right;color:var(--red)">${fn(r.neg_q)}</td><td style="text-align:right;color:var(--red)">${f8(r.neg_a)}</td></tr>`;});
document.getElementById("warn-box").textContent="총 "+f8(negItems.reduce((s,r)=>s+r.neg_a,0))+" — 즉시 확인";

// P6
document.getElementById("fx-cnt").textContent=new Set(fix.map(r=>r.name)).size+"개점";
const bf=fix.length?fix.reduce((a,b)=>a.pm>b.pm?a:b):{pm:0,name:"—",cell:""};
document.getElementById("fx-pm").textContent=(bf.pm||0).toFixed(1);document.getElementById("fx-pm-d").textContent=bf.name+" "+bf.cell;
const tv=fix.filter(r=>r.tcr),mv=fix.filter(r=>r.margin);
document.getElementById("fx-tcr").textContent=tv.length?(tv.reduce((s,r)=>s+r.tcr,0)/tv.length).toFixed(1)+"%":"—";
document.getElementById("fx-mg").textContent=mv.length?(mv.reduce((s,r)=>s+r.margin,0)/mv.length).toFixed(1)+"%":"—";
const fxBr=[...new Set(fix.map(r=>r.name))];
new Chart(document.getElementById("c-fx"),{type:"bar",data:{labels:fxBr,datasets:["남성","여성","아동"].map((cn,ci)=>{const cols=["rgba(78,205,196,.75)","rgba(255,107,157,.75)","rgba(255,209,102,.75)"];return{label:cn,data:fxBr.map(b=>{const r=fix.find(r=>r.name===b&&r.cell===cn);return r?r.pm:0;}),backgroundColor:cols[ci],borderRadius:3,barPercentage:0.7};})},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:true,position:"top",labels:{color:lc,font:{size:10},boxWidth:10}},tooltip:{callbacks:{label:c=>c.dataset.label+": "+c.raw+"만/평"}}},scales:{x:{grid:{color:gc},ticks:{color:lc,font:{size:9}}},y:{grid:{color:gc},ticks:{color:lc,font:{size:9},callback:v=>v+"만"}}}}});
const ft=document.getElementById("fx-tbl");
fix.forEach(r=>{ft.innerHTML+=`<tr><td>${r.name}</td><td style="color:${CC[r.cell]||"var(--text2)"}">${r.cell}</td><td style="text-align:right;color:var(--text3)">${r.area}평</td><td style="text-align:right">${f8(r.total)}</td><td style="text-align:right;color:var(--yellow);font-weight:600">${r.pm}만</td><td style="text-align:right">${pil(r.margin||0,20,0)}</td></tr>`;});

// 필터
function filterType(type,el){
  currentType=type;
  document.querySelectorAll(".tf-btn").forEach(b=>b.classList.remove("on"));
  el.classList.add("on");
  const filtered=type==="전체"?branches:branches.filter(b=>b.type===type);
  initP1(filtered);
  const cF={남성:0,여성:0,아동:0};
  filtered.forEach(b=>{(cellByBranch[b.name]||[]).forEach(c=>{cF[c.cell]=(cF[c.cell]||0)+(c.total||0);});});
  document.getElementById("s-m").textContent=f8(cF["남성"]);
  document.getElementById("s-w").textContent=f8(cF["여성"]);
  document.getElementById("s-k").textContent=f8(cF["아동"]);
  document.getElementById("s-br").textContent=filtered.length;
  document.getElementById("k-tot").textContent=f8(filtered.reduce((s,b)=>s+(b.total||0),0));
}

// 상세 패널
function openDetail(bn){
  const cells=cellByBranch[bn]||[],dayData=dailyByBranch[bn]||[],brInfo=branches.find(b=>b.name===bn)||{};
  document.getElementById("dp-name").textContent=bn;
  document.getElementById("dp-meta").textContent=(brInfo.type||"")+" · 2026년 4월 · 8일분";
  const totC=cells.reduce((s,c)=>s+(c.total||0),0),totN=cells.reduce((s,c)=>s+(c.net||0),0),totCo=cells.reduce((s,c)=>s+(c.cost||0),0),totLy=cells.reduce((s,c)=>s+(c.ly||0),0),totInv=cells.reduce((s,c)=>s+(c.inv_amt||0),0);
  const avgMg=totN>0?((totN-totCo)/totN*100).toFixed(1):null,sellR=totCo+totInv>0?(totCo/(totCo+totInv)*100).toFixed(1):null,gro=totLy>0?((totC/totLy-1)*100).toFixed(1):null;
  document.getElementById("dp-krow").innerHTML=`<div class="dp-kpi"><div class="dp-kpi-l">누계 실적</div><div class="dp-kpi-v" style="color:var(--teal)">${f8(totC)}</div><div class="dp-kpi-s">일평균 ${f8(totC/8)}</div></div><div class="dp-kpi"><div class="dp-kpi-l">매총율</div><div class="dp-kpi-v" style="color:var(--pink)">${avgMg?avgMg+"%":"—"}</div><div class="dp-kpi-s">순이익/실매출</div></div><div class="dp-kpi"><div class="dp-kpi-l">판매율</div><div class="dp-kpi-v" style="color:var(--yellow)">${sellR?sellR+"%":"—"}</div><div class="dp-kpi-s">원가/입고원가</div></div><div class="dp-kpi"><div class="dp-kpi-l">전년 성장</div><div class="dp-kpi-v" style="color:${gro&&+gro>=0?"var(--green)":"var(--red)"}">${gro?(+gro>=0?"+":"")+gro+"%":"—"}</div><div class="dp-kpi-s">YoY</div></div>`;
  if(dpChart){dpChart.destroy();dpChart=null;}
  dpChart=new Chart(document.getElementById("dp-chart"),{type:"line",data:{labels:dayData.map(r=>r.d),datasets:[{label:"실적",data:dayData.map(r=>r.t),borderColor:"var(--teal)",backgroundColor:"rgba(78,205,196,.1)",borderWidth:2,pointRadius:3,pointBackgroundColor:"var(--teal)",fill:true,tension:0.3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>f8(c.raw)}}},scales:{x:{grid:{color:gc},ticks:{color:lc,font:{size:9}}},y:{grid:{color:gc},ticks:{color:lc,font:{size:9},callback:v=>f8(v)}}}}});
  const ctbl=document.getElementById("dp-ctbl");ctbl.innerHTML="";
  cells.forEach(c=>{const g=c.growth;ctbl.innerHTML+=`<tr><td style="color:${CC[c.cell]||"var(--text)"}">${c.cell}</td><td style="text-align:right">${f8(c.total)}</td><td style="text-align:right;color:var(--text3)">${c.ly?f8(c.ly):"—"}</td><td style="text-align:right;color:${g&&+g>=0?"var(--green)":"var(--red)"}">${g?(+g>=0?"+":"")+g+"%":"—"}</td><td style="text-align:right">${pil(c.sell_rate||0,30,15)}</td><td style="text-align:right">${pil(c.margin||0,20,0)}</td><td style="text-align:right;color:var(--purple)">${c.pm?c.pm+"만/평":"—"}</td></tr>`;});
  const diag=document.getElementById("dp-diag");diag.innerHTML="";
  [{label:"매출 성장율",desc:`전년 대비 ${gro?gro+"%":"데이터 없음"}`,st:gro&&+gro>=10?"ok":gro&&+gro>=0?"warn":"alert",dot:"var(--teal)"},
   {label:"매총율",desc:`${avgMg?avgMg+"%":"—"} ${avgMg&&+avgMg>=20?"▲ 양호":"▼ 점검"}`,st:avgMg&&+avgMg>=20?"ok":avgMg&&+avgMg>=0?"warn":"alert",dot:"var(--pink)"},
   {label:"판매율",desc:`${sellR?sellR+"%":"—"} ${sellR&&+sellR>=30?"▲ 양호":"▼ 재고 주의"}`,st:sellR&&+sellR>=30?"ok":sellR&&+sellR>=15?"warn":"alert",dot:"var(--yellow)"},
  ].forEach(it=>{diag.innerHTML+=`<div class="dp-ind"><div class="dp-ind-l"><div class="ind-dot" style="background:${it.dot}"></div><div><div class="ind-label">${it.label}</div><div class="ind-desc">${it.desc}</div></div></div><span class="ind-badge b-${it.st}">${it.st==="ok"?"정상":it.st==="warn"?"주의":"점검"}</span></div>`;});
  document.getElementById("overlay").classList.add("open");
}
function closePanel(){document.getElementById("overlay").classList.remove("open");}
function closeDetail(e){if(e.target===document.getElementById("overlay"))closePanel();}
initP1();
</script>

<script>
// PWA 서비스워커 등록
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('./sw.js')
      .then(reg => console.log('[PWA] 서비스워커 등록 완료:', reg.scope))
      .catch(err => console.log('[PWA] 서비스워커 등록 실패:', err));
  });
}

// iOS Safari에서 홈 화면 추가 안내 배너
function showInstallBanner() {
  const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
  const isInStandalone = ('standalone' in navigator) && navigator.standalone;
  const bannerDismissed = localStorage.getItem('pwa-banner-dismissed');
  
  if (isIOS && !isInStandalone && !bannerDismissed) {
    setTimeout(() => {
      const banner = document.createElement('div');
      banner.id = 'install-banner';
      banner.style.cssText = `
        position:fixed;bottom:calc(60px + env(safe-area-inset-bottom));left:50%;
        transform:translateX(-50%);background:#252220;border:1px solid #4ECDC4;
        border-radius:12px;padding:12px 16px;width:calc(100% - 32px);max-width:380px;
        z-index:1000;box-shadow:0 4px 24px rgba(0,0,0,.5);
        display:flex;align-items:center;gap:10px;font-family:inherit;
      `;
      banner.innerHTML = `
        <img src="icons/icon-72.png" style="width:40px;height:40px;border-radius:8px;flex-shrink:0">
        <div style="flex:1">
          <div style="font-size:12px;font-weight:700;color:#F0EDE8;margin-bottom:2px">홈 화면에 추가하기</div>
          <div style="font-size:10px;color:#7A7268;line-height:1.4">
            Safari 하단의 <span style="color:#4ECDC4">공유 버튼 →</span> 홈 화면에 추가
          </div>
        </div>
        <button onclick="document.getElementById('install-banner').remove();localStorage.setItem('pwa-banner-dismissed','1')"
          style="background:none;border:none;color:#7A7268;font-size:18px;cursor:pointer;padding:4px;flex-shrink:0">✕</button>
      `;
      document.body.appendChild(banner);
    }, 3000);
  }
}

// Android/Chrome 설치 프롬프트
let deferredPrompt;
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredPrompt = e;
  
  const btn = document.createElement('button');
  btn.id = 'install-btn';
  btn.style.cssText = `
    position:fixed;bottom:calc(70px + env(safe-area-inset-bottom));right:16px;
    background:#4ECDC4;color:#1C1A17;border:none;border-radius:24px;
    padding:10px 18px;font-size:12px;font-weight:700;cursor:pointer;
    font-family:inherit;z-index:1000;box-shadow:0 4px 16px rgba(78,205,196,.4);
    display:flex;align-items:center;gap:6px;
  `;
  btn.innerHTML = '📲 앱 설치';
  btn.onclick = async () => {
    btn.remove();
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    console.log('[PWA] 설치 결과:', outcome);
    deferredPrompt = null;
  };
  document.body.appendChild(btn);
});

window.addEventListener('appinstalled', () => {
  document.getElementById('install-btn')?.remove();
  console.log('[PWA] 앱 설치 완료!');
});

showInstallBanner();
</script>
</body>
</html>